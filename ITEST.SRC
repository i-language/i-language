using System;
using System.IO;
using System.Collections.Generic;
using Gtk;
using Cairo;
using Pango;

public class GtkStablePrinting
{
    // 書式データ保持用クラス
    public class FormatItem
    {
        public string Type;
        public double X1, Y1, X2, Y2;
        public string FontName;
        public double FontSize;
    }

    private List<FormatItem> formatList = new List<FormatItem>();
    private List<string> dataList = new List<string>();
    private int itemsPerPage = 0;

    public static void Main(string[] args)
    {
        // GTKの初期化
        Application.Init();
        
        GtkStablePrinting app = new GtkStablePrinting();
        app.Execute();
        
        // メッセージ表示
        Console.WriteLine("処理が完了しました。プログラムと同じフォルダの output.pdf を確認してください。");
    }

    public void Execute()
    {
        try
        {
            // 1. ファイル読み込み
            if (!LoadFiles()) return;

            // 2. 1ページあたりの項目数（TEXT行数）を計算
            itemsPerPage = 0;
            foreach (FormatItem item in formatList)
            {
                if (item.Type == "TEXT") itemsPerPage++;
            }
            if (itemsPerPage == 0) itemsPerPage = 1;

            // 3. 総ページ数の計算
            double totalDataCount = (double)dataList.Count;
            int totalPages = (int)Math.Ceiling(totalDataCount / itemsPerPage);
            if (totalPages == 0) totalPages = 1;

            // 4. PDFサーフェスの作成（A4サイズ: 595x842 ポイント）
            string outputFileName = "output.pdf";
            PdfSurface surface = new PdfSurface(outputFileName, 595, 842);
            
            // 【修正箇所】Cairo.Context と明示して曖昧さを回避
            Cairo.Context cr = new Cairo.Context(surface);

            // 5. ページごとの描画ループ
            int currentPage = 0;
            while (currentPage < totalPages)
            {
                DrawOnePage(cr, currentPage);
                // ページを確定させて次へ
                cr.ShowPage();
                currentPage++;
            }

            // 6. 後片付け（IDisposableへのキャストで確実に破棄）
            ((IDisposable)cr).Dispose();
            ((IDisposable)surface).Dispose();
        }
        catch (Exception ex)
        {
            Console.WriteLine("例外発生: " + ex.Message);
            Console.WriteLine(ex.StackTrace);
        }
    }

    // 【修正箇所】引数の型を Cairo.Context に明示
    private void DrawOnePage(Cairo.Context cr, int pageNum)
    {
        int dataStartIndex = pageNum * itemsPerPage;
        int currentDataOffset = 0;

        foreach (FormatItem item in formatList)
        {
            if (item.Type == "LINE")
            {
                cr.SetSourceRGB(0, 0, 0);
                cr.MoveTo(item.X1, item.Y1);
                cr.LineTo(item.X2, item.Y2);
                cr.LineWidth = 1.0;
                cr.Stroke();
            }
            else if (item.Type == "TEXT")
            {
                int dataIndex = dataStartIndex + currentDataOffset;
                if (dataIndex < dataList.Count)
                {
                    string text = dataList[dataIndex];
                    
                    // Pangoレイアウトの作成
                    Pango.Layout layout = Pango.CairoHelper.CreateLayout(cr);
                    Pango.FontDescription fontDesc = Pango.FontDescription.FromString(item.FontName + " " + item.FontSize);
                    
                    layout.FontDescription = fontDesc;
                    layout.SetText(text);

                    cr.MoveTo(item.X1, item.Y1);
                    Pango.CairoHelper.ShowLayout(cr, layout);

                    fontDesc.Dispose();
                    layout.Dispose();
                }
                currentDataOffset++;
            }
        }
    }

    private bool LoadFiles()
    {
        if (!File.Exists("format.txt") || !File.Exists("data.txt"))
        {
            Console.WriteLine("エラー: format.txt または data.txt が見つかりません。");
            return false;
        }

        // フォーマット読み込み
        string[] fLines = File.ReadAllLines("format.txt");
        foreach (string line in fLines)
        {
            if (string.IsNullOrWhiteSpace(line)) continue;
            string[] parts = line.Split(',');
            FormatItem item = new FormatItem();
            item.Type = parts[0].Trim().ToUpper();
            
            if (item.Type == "TEXT" && parts.Length >= 5)
            {
                item.X1 = double.Parse(parts[1]);
                item.Y1 = double.Parse(parts[2]);
                item.FontName = parts[3].Trim();
                item.FontSize = double.Parse(parts[4]);
                formatList.Add(item);
            }
            else if (item.Type == "LINE" && parts.Length >= 5)
            {
                item.X1 = double.Parse(parts[1]);
                item.Y1 = double.Parse(parts[2]);
                item.X2 = double.Parse(parts[3]);
                item.Y2 = double.Parse(parts[4]);
                formatList.Add(item);
            }
        }

        // データ読み込み
        string[] dLines = File.ReadAllLines("data.txt");
        foreach (string line in dLines)
        {
            if (!string.IsNullOrWhiteSpace(line))
            {
                dataList.Add(line);
            }
        }

        return true;
    }
}

